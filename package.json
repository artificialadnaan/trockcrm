{
  "name": "trock-crm",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "worker",
    "client"
  ],
  "scripts": {
    "dev:shared": "npm run build --workspace=shared",
    "dev:server": "npm run dev --workspace=server",
    "dev:worker": "npm run dev --workspace=worker",
    "dev:client": "npm run dev --workspace=client",
    "dev": "npm run dev:shared && concurrently \"npm:dev:shared -- --watch\" \"npm:dev:server\" \"npm:dev:worker\" \"npm:dev:client\"",
    "build": "npm run build --workspaces",
    "start:api": "node server/dist/index.js",
    "start:worker": "node worker/dist/index.js",
    "start:client": "npx serve client/dist -s -l 3000",
    "typecheck": "npm run build --workspace=shared && npm run typecheck --workspaces",
    "test": "npm run test --workspace=server",
    "validate:admin-users-volume": "node scripts/playwright-admin-users-volume-validation.mjs",
    "seed:policy-recommendation-qualification": "node --import tsx scripts/seed-intervention-policy-recommendation-qualification.ts",
    "db:generate": "drizzle-kit generate --config=shared/drizzle.config.ts",
    "db:migrate": "tsx server/src/migrations/runner.ts",
    "db:studio": "drizzle-kit studio --config=shared/drizzle.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.1.2",
    "playwright": "^1.59.1",
    "typescript": "^5.7.3"
  }
}
